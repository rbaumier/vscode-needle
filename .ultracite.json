{
  "exclude": ["node_modules", "out", "test-fixtures", "rust-fuzzy"],
  "extends": ["ultracite:recommended"],
  "include": ["src/**/*.ts"],
  "rules": {
    "import-order": {
      "alphabetize": {
        "order": "asc"
      },
      "enabled": true,
      "groups": ["builtin", "external", "internal", "parent", "sibling", "index"]
    },
    "no-default-export": {
      "enabled": false
    },
    "prefer-named-exports": {
      "enabled": true
    }
  }
}
