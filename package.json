{
  "name": "needle",
  "displayName": "Needle — Find in current file",
  "description": "Fast in-file search powered by Rust. Find any text in the active file instantly.",
  "publisher": "rbaumier",
  "version": "1.0.0",
  "license": "MIT",
  "homepage": "https://github.com/rbaumier/vscode-needle",
  "repository": {
    "type": "git",
    "url": "https://github.com/rbaumier/vscode-needle.git"
  },
  "bugs": {
    "url": "https://github.com/rbaumier/vscode-needle/issues"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "packageManager": "bun@1.2.21",
  "categories": [
    "Other"
  ],
  "main": "./out/main.js",
  "activationEvents": [
    "onCommand:needle.find"
  ],
  "contributes": {
    "commands": [
      {
        "command": "needle.find",
        "title": "Needle: Find in file"
      }
    ]
  },
  "scripts": {
    "format": "oxfmt ./src",
    "check": "oxfmt --check ./src",
    "build": "bun build ./src/main.ts --outdir=./out --target=node --format=cjs --minify --external=vscode",
    "build:dev": "bun build ./src/main.ts --outdir=./out --target=node --format=cjs --sourcemap=external --external=vscode",
    "build:test": "bun build ./test/e2e/extension.e2e.test.ts --outdir=./out/test/e2e --target=node --format=cjs --external=vscode --external=assert --external=mocha",
    "build:rust": "cd rust-needle && napi build --platform --release",
    "build:all": "bun run build:rust && bun run build",
    "clean": "rm -rf out/ *.vsix",
    "rebuild": "bun run clean && bun run build:all",
    "watch": "bun build ./src/main.ts --outdir=./out --target=node --format=cjs --external=vscode --watch",
    "test:e2e": "bun run build:dev && bun run build:test && vscode-test",
    "package": "bun x vsce package --no-dependencies",
    "publish:vscode": "bun x vsce publish --no-dependencies",
    "publish:ovsx": "bun x ovsx publish -p $OVSX_TOKEN",
    "publish:all": "bun run publish:vscode && bun run publish:ovsx"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18",
    "@types/vscode": "^1.55.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.2",
    "mocha": "^11.7.4",
    "ovsx": "^0.10.6",
    "oxfmt": "^0.42.0",
    "typescript": "^5.0.0"
  }
}
